{
	"name": "n8n-nodes-maibaoapi",
	"version": "1.3.0",
	"description": "便捷调用 MaibaoAPI 进行文字生成、图像生成、音频转文本。",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package","n8n-nodes-maibaoapi","maibaoapi","maibao","文字生成","图像生成","GPT-image-2","音频转文本","nano banana2"
	],
	"author": {
		"name": "毛淞淮",
		"email": "263674673@qq.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kkuxb/n8n-nodes-maibaoapi.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "node scripts/dev.mjs",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test:gpt-image-2": "node --test test/gpt-image-2.test.js",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MaibaoApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MaibaoApi/MaibaoApi.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^25.0.3",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
